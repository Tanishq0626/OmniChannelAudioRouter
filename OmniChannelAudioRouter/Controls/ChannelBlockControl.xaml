<UserControl x:Class="OmniChannelAudioRouter.Controls.ChannelBlockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <md:Card Style="{StaticResource ChannelCardStyle}">
        <StackPanel>
            <!-- Channel Title -->
            <TextBlock x:Name="TitleText"
                       Style="{StaticResource ChannelTitleStyle}"/>

            <!-- Audio Device Selector -->
            <ComboBox x:Name="DeviceComboBox"
                      md:HintAssist.Hint="Audio Output Device"
                      Style="{StaticResource ChannelComboBoxStyle}"
                      SelectedIndex="0">
                <ComboBoxItem Content="Realtek Speakers"/>
                <ComboBoxItem Content="Bluetooth Speaker"/>
                <ComboBoxItem Content="HDMI Audio"/>
                <ComboBoxItem Content="USB DAC"/>
                <ComboBoxItem Content="Wireless Headphones"/>
            </ComboBox>

            <!-- Speaker Layout Selector -->
            <ComboBox x:Name="LayoutComboBox"
                      md:HintAssist.Hint="Speaker Layout"
                      Style="{StaticResource ChannelComboBoxStyle}"
                      SelectedIndex="2">
                <ComboBoxItem Content="Mono"/>
                <ComboBoxItem Content="Only Subwoofer"/>
                <ComboBoxItem Content="2.0 Stereo"/>
                <ComboBoxItem Content="2.1 Front"/>
                <ComboBoxItem Content="2.1 Rear"/>
                <ComboBoxItem Content="4.0 Quad"/>
                <ComboBoxItem Content="4.1 Surround"/>
                <ComboBoxItem Content="5.1 Surround"/>
                <ComboBoxItem Content="7.1 Surround"/>
                <ComboBoxItem Content="5.1.2 Atmos"/>
            </ComboBox>

            <!-- Latency Buffer -->
            <TextBox x:Name="LatencyTextBox"
                     md:HintAssist.Hint="Manual Latency Buffer (ms)"
                     Style="{StaticResource ChannelTextBoxStyle}"
                     Text="0"/>

            <!-- Volume Slider -->
            <TextBlock Text="Volume Protection Ceiling"
                       Style="{StaticResource VolumeLabelStyle}"/>

            <DockPanel Margin="0,0,0,5">
                <TextBlock x:Name="VolumePercentText"
                           Text="50%"
                           Style="{StaticResource VolumePercentStyle}"
                           DockPanel.Dock="Right"/>
                <Slider x:Name="VolumeSlider"
                        Style="{StaticResource VolumeSliderStyle}"
                        Value="50"
                        ValueChanged="VolumeSlider_ValueChanged"/>
            </DockPanel>
        </StackPanel>
    </md:Card>
</UserControl>
