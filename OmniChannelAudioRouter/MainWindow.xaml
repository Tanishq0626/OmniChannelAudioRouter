<Window x:Class="OmniChannelAudioRouter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:OmniChannelAudioRouter.Controls"
        Title="OmniChannel Audio Router Dashboard" Height="650" Width="950"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <md:ColorZone Mode="PrimaryMid" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎧 OmniChannel Audio Router" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="v1.0 (Material Design Engine)" FontSize="12" Margin="15,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
            </StackPanel>
        </md:ColorZone>

        <!-- Channel Blocks -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="16">

            <controls:ChannelBlockControl
                ChannelTitle="Audio Channel 1"
                TitleColor="{DynamicResource PrimaryHueMidBrush}"
                DefaultVolume="11"
                DefaultLatency="0"/>

            <controls:ChannelBlockControl
                ChannelTitle="Audio Channel 2"
                TitleColor="{DynamicResource SecondaryHueMidBrush}"
                DefaultVolume="100"
                DefaultLatency="240"/>

            <controls:ChannelBlockControl
                ChannelTitle="Audio Channel 3"
                TitleColor="Orange"
                DefaultVolume="75"
                DefaultLatency="10"/>

        </UniformGrid>

        <!-- Footer -->
        <md:ColorZone Grid.Row="2" Mode="PrimaryDark" Padding="12,8">
            <DockPanel>
                <Button x:Name="TestButton" Content="▶ Run Test" Click="TestButton_Click"
                        Style="{StaticResource MaterialDesignFlatLightBgButton}"
                        DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <TextBlock x:Name="StatusText" Text="Ready  •  All channels idle" VerticalAlignment="Center" FontSize="13" Opacity="0.85"/>
            </DockPanel>
        </md:ColorZone>
    </Grid>
</Window>
